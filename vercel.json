{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}
